#	===	Base de	données	PostgreSQL	===
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me_super_secret
POSTGRES_DB=app_db
#	===	Ports exposés	sur	la	machine	hôte	===
#	On	choisit	des	ports	LIBRES	pour	ne	pas	entrer	en	conflit
#	avec	l'application	déjà	présente	sur	le	serveur	(voir	Partie	10).
FRONTEND_PORT=8090
BACKEND_PORT=8001
DB_PORT=5433
#	===	URL	de	l'API	vue	par	le	frontend	(navigateur)	===
VITE_API_URL = http://localhost:8001